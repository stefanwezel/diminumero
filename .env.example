# Flask Configuration
# Generate a secure secret key for production using:
# python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-secret-key-here-change-this-in-production

# Site URL (used for canonical URLs, sitemap, robots.txt)
SITE_URL=https://diminumero.com

# Auth0 (Regular Web Application) — required for /login, /callback, /cards
# Find these values in your Auth0 dashboard under Applications > diminumero
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
